# === VENDURE API ===
VENDURE_API_URL=http://localhost:3001/shop-api
VENDURE_CHANNEL_TOKEN=

# === SITE CONFIG ===
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_COOKIE_DOMAIN=

# === META PIXEL / CONVERSIONS API (optional) ===
PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_DATASET_ID=

# === BRANDING ===
# All branding comes from Vendure Channel custom fields (not env vars).
# Configure in Vendure Dashboard: Settings > Channels > [your channel]
# Fields: storeName, storeTagline, contactEmail, contactPhone,
#         freeShippingThreshold, promoBarText, promoBarLink,
#         companyName, companyNip, companyAddress, returnAddress,
#         storefrontUrl, inpostGeowidgetToken
