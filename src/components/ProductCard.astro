---
import Price from './Price.astro';
import { buildAssetUrl } from '@/lib/utils';

interface Props {
  name: string;
  slug: string;
  imageUrl?: string;
  priceWithTax: { __typename: string; min?: number; max?: number; value?: number };
  currencyCode?: string;
}

const { name, slug, imageUrl, priceWithTax, currencyCode = 'PLN' } = Astro.props;
---

<a
  href={`/produkty/${slug}`}
  class="group block no-underline"
>
  <div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
    {imageUrl ? (
      <img
        src={buildAssetUrl(imageUrl, 'medium')}
        alt={name}
        width="400"
        height="400"
        loading="lazy"
        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      />
    ) : (
      <div class="flex h-full w-full items-center justify-center text-gray-400">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    )}
  </div>
  <div class="mt-3 space-y-1">
    <h3 class="text-sm font-medium text-gray-900 group-hover:text-gray-600 transition-colors line-clamp-2">
      {name}
    </h3>
    <Price priceRange={priceWithTax} currencyCode={currencyCode} class="text-sm" />
  </div>
</a>
