---
interface Props {
  provider?: 'trustmate' | 'opineo' | 'custom';
  scriptSrc?: string;
  widgetId?: string;
  title?: string;
  fallbackText?: string;
}

const {
  provider = 'custom',
  scriptSrc,
  widgetId = 'reviews-widget',
  title = 'Opinie klientow',
  fallbackText = 'Sekcja opinii — skonfiguruj dostawce (TrustMate, Opineo) w ustawieniach sklepu',
} = Astro.props;

const hasProvider = provider !== 'custom' && scriptSrc;
---

<section class="py-12 sm:py-16">
  <div class="mx-auto max-w-4xl px-4">
    <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">{title}</h2>

    {hasProvider ? (
      <div>
        <div id={widgetId}></div>
        <script src={scriptSrc} defer></script>
      </div>
    ) : (
      <div class="border-2 border-dashed border-gray-300 rounded-2xl p-8 sm:p-12 text-center">
        {/* Stars icon */}
        <div class="flex items-center justify-center gap-1 mb-4">
          {[1, 2, 3, 4, 5].map(() => (
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="w-6 h-6 text-gray-300"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))}
        </div>
        <p class="text-gray-400 text-sm">{fallbackText}</p>
      </div>
    )}
  </div>
</section>
