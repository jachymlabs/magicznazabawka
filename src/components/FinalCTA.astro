---
import { formatPrice } from '@/lib/utils';

interface Props {
  productName: string;
  /** Cena w groszach */
  price: number;
  variantId: string;
  image?: string;
  urgencyText?: string;
}

const {
  productName,
  price,
  variantId,
  image,
  urgencyText,
} = Astro.props;

const formattedPrice = formatPrice(price);
---

<section class="bg-gray-50 border-t border-gray-200">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
    <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-center sm:justify-center sm:gap-6">
      {/* Image */}
      {image && (
        <div class="shrink-0 w-20 h-20 rounded-lg overflow-hidden bg-gray-100">
          <img
            src={image}
            alt={productName}
            width={80}
            height={80}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      )}

      {/* Name + price */}
      <div class="text-center sm:text-left">
        <p class="text-base font-semibold text-gray-900">{productName}</p>
        <p class="text-sm font-medium text-gray-600 mt-0.5">{formattedPrice}</p>
      </div>

      {/* ATC form */}
      <form method="POST" action="/api/cart" class="w-full sm:w-auto shrink-0">
        <input type="hidden" name="variantId" value={variantId} />
        <input type="hidden" name="quantity" value="1" />
        <button
          type="submit"
          id="final-cta-btn"
          class="w-full sm:w-auto rounded-lg bg-gray-900 px-6 py-3 text-sm font-semibold text-white hover:bg-gray-800 active:bg-gray-700 transition-colors min-h-[44px]"
        >
          Wyprobuj bez ryzyka — 14 dni na zwrot
        </button>
      </form>
    </div>

    {/* Urgency text */}
    {urgencyText && (
      <p class="text-center text-xs text-amber-700 font-medium mt-3">
        {urgencyText}
      </p>
    )}
  </div>
</section>
