---
import type { FaqAccordionProps } from '../../types/sections';
import IconRenderer from './IconRenderer.astro';
import { sanitizeHtml } from '@/lib/sanitize';

interface Props extends FaqAccordionProps {}

const {
  id,
  theme = 'light',
  paddingY = 'md',
  headline,
  items,
} = Astro.props;

const bgClasses: Record<string, string> = {
  light: 'bg-white text-gray-900',
  dark: 'bg-gray-900 text-white',
  brand: 'bg-blue-600 text-white',
  accent: 'bg-amber-50 text-gray-900',
};

const paddingClasses: Record<string, string> = {
  none: '',
  sm: 'py-8',
  md: 'py-12',
  lg: 'py-16',
  xl: 'py-24',
};

const borderColor = theme === 'light' || theme === 'accent' ? 'divide-gray-200' : 'divide-white/10';
---

<section
  id={id}
  class:list={[bgClasses[theme], paddingClasses[paddingY]]}
>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    {headline && (
      <h2 class="mb-10 text-center text-2xl font-bold sm:text-3xl">
        {headline}
      </h2>
    )}

    <div class:list={['divide-y', borderColor]}>
      {items.map((item) => (
        <details class="group">
          <summary class="flex cursor-pointer items-center justify-between py-4 font-medium">
            <span>{item.question}</span>
            <span class="chevron ml-4 shrink-0 transition-transform duration-200 group-open:rotate-180">
              <IconRenderer name="chevron-down" size={20} />
            </span>
          </summary>
          <div class:list={[
            'rich-text pb-4 text-sm',
            theme === 'light' || theme === 'accent' ? 'text-gray-600' : 'text-white/70',
          ]} set:html={sanitizeHtml(item.answer)} />
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details summary::-webkit-details-marker {
    display: none;
  }
  details summary {
    list-style: none;
  }
</style>
