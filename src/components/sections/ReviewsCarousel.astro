---
import type { ReviewsCarouselProps } from '../../types/sections';

interface Props extends ReviewsCarouselProps {}

const {
  id,
  theme = 'light',
  paddingY = 'md',
  headline,
  reviews,
} = Astro.props;

const bgClasses: Record<string, string> = {
  light: 'bg-white text-gray-900',
  dark: 'bg-gray-900 text-white',
  brand: 'bg-blue-600 text-white',
  accent: 'bg-amber-50 text-gray-900',
};

const paddingClasses: Record<string, string> = {
  none: '',
  sm: 'py-8',
  md: 'py-12',
  lg: 'py-16',
  xl: 'py-24',
};

const isLight = theme === 'light' || theme === 'accent';
const cardBg = isLight ? 'bg-gray-50' : 'bg-white/5';
const authorColor = isLight ? 'text-gray-500' : 'text-white/60';
---

<section
  id={id}
  class:list={[bgClasses[theme], paddingClasses[paddingY]]}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {headline && (
      <h2 class="mb-10 text-center text-2xl font-bold sm:text-3xl">
        {headline}
      </h2>
    )}

    <div class="flex gap-4 overflow-x-auto pb-4 snap-x snap-mandatory scrollbar-hide">
      {reviews.map((review) => {
        const stars = Array.from({ length: 5 }, (_, i) => i < Math.round(review.rating));
        return (
          <div class:list={[
            'flex min-w-[280px] max-w-[340px] shrink-0 snap-start flex-col rounded-xl p-5',
            cardBg,
          ]}>
            <div class="mb-2 flex gap-0.5">
              {stars.map((filled) => (
                <span class:list={['text-sm', filled ? 'text-amber-400' : 'text-gray-300']}>
                  &#9733;
                </span>
              ))}
            </div>
            {review.title && (
              <p class="mb-1 font-semibold text-sm">{review.title}</p>
            )}
            <p class="flex-1 text-sm leading-relaxed">{review.body}</p>
            <p class:list={['mt-3 text-xs font-medium', authorColor]}>
              {review.author}
            </p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
