---
import type { FeaturesGridProps } from '../../types/sections';
import IconRenderer from './IconRenderer.astro';

interface Props extends FeaturesGridProps {}

const {
  id,
  theme = 'light',
  paddingY = 'md',
  headline,
  features,
  columns = 3,
} = Astro.props;

const bgClasses: Record<string, string> = {
  light: 'bg-white text-gray-900',
  dark: 'bg-gray-900 text-white',
  brand: 'bg-blue-600 text-white',
  accent: 'bg-amber-50 text-gray-900',
};

const paddingClasses: Record<string, string> = {
  none: '',
  sm: 'py-8',
  md: 'py-12',
  lg: 'py-16',
  xl: 'py-24',
};

const colClasses: Record<number, string> = {
  2: 'md:grid-cols-2',
  3: 'md:grid-cols-3',
  4: 'md:grid-cols-4',
};

const iconBg = theme === 'light' || theme === 'accent' ? 'bg-gray-100' : 'bg-white/10';
const descColor = theme === 'light' || theme === 'accent' ? 'text-gray-600' : 'text-white/70';
---

<section
  id={id}
  class:list={[bgClasses[theme], paddingClasses[paddingY]]}
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    {headline && (
      <h2 class="mb-10 text-center text-2xl font-bold sm:text-3xl">
        {headline}
      </h2>
    )}

    <div class:list={['grid gap-8', colClasses[columns]]}>
      {features.map((feature) => (
        <div class="flex flex-col items-center text-center">
          <div class:list={['mb-4 flex items-center justify-center rounded-full p-3', iconBg]}>
            <IconRenderer name={feature.icon} size={24} />
          </div>
          <h3 class="mb-1 font-semibold">{feature.title}</h3>
          <p class:list={['text-sm', descColor]}>{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
