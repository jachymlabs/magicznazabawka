---
import type { ComparisonTableProps } from '../../types/sections';

interface Props extends ComparisonTableProps {}

const {
  id,
  theme = 'light',
  paddingY = 'md',
  headline,
  ourBrand,
  competitor,
  rows,
} = Astro.props;

const bgClasses: Record<string, string> = {
  light: 'bg-white text-gray-900',
  dark: 'bg-gray-900 text-white',
  brand: 'bg-blue-600 text-white',
  accent: 'bg-amber-50 text-gray-900',
};

const paddingClasses: Record<string, string> = {
  none: '',
  sm: 'py-8',
  md: 'py-12',
  lg: 'py-16',
  xl: 'py-24',
};

const isLight = theme === 'light' || theme === 'accent';
const borderClass = isLight ? 'border-gray-200' : 'border-white/10';
const stripeBg = isLight ? 'even:bg-gray-50' : 'even:bg-white/5';
---

<section
  id={id}
  class:list={[bgClasses[theme], paddingClasses[paddingY]]}
>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    {headline && (
      <h2 class="mb-10 text-center text-2xl font-bold sm:text-3xl">
        {headline}
      </h2>
    )}

    <div class="overflow-x-auto">
      <table class:list={['w-full min-w-[480px] border-collapse text-sm', borderClass]}>
        <thead>
          <tr class:list={['border-b', borderClass]}>
            <th class="py-3 pr-4 text-left font-medium">Cecha</th>
            <th class:list={[
              'border-x px-4 py-3 text-center font-bold',
              borderClass,
              isLight ? 'bg-green-50' : 'bg-green-900/20',
            ]}>
              {ourBrand}
            </th>
            <th class="py-3 pl-4 text-center font-medium">
              {competitor}
            </th>
          </tr>
        </thead>
        <tbody>
          {rows.map((row) => (
            <tr class:list={['border-b', borderClass, stripeBg]}>
              <td class="py-3 pr-4">{row.feature}</td>
              <td class:list={['border-x px-4 py-3 text-center', borderClass]}>
                {row.us ? (
                  <span class="text-green-600 font-bold">&#10003;</span>
                ) : (
                  <span class="text-gray-400">&#10007;</span>
                )}
              </td>
              <td class="py-3 pl-4 text-center">
                {row.them ? (
                  <span class="text-gray-400">&#10003;</span>
                ) : (
                  <span class="text-gray-400">&#10007;</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
