---
/**
 * TrustBadges — rzad ikon zaufania pod przyciskiem ATC.
 * Mobile: 2x2 grid, Desktop: inline row.
 */
---

<div class="grid grid-cols-2 sm:flex sm:flex-row sm:items-center gap-4 mt-4">
  <!-- BLIK -->
  <div class="flex items-center gap-1.5 text-gray-500">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="5" y="3" width="14" height="18" rx="2" />
      <text x="12" y="15" text-anchor="middle" font-size="10" font-weight="bold" fill="currentColor" stroke="none">B</text>
    </svg>
    <span class="text-xs">BLIK</span>
  </div>

  <!-- InPost -->
  <div class="flex items-center gap-1.5 text-gray-500">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="3" y="4" width="18" height="16" rx="1" />
      <line x1="3" y1="10" x2="21" y2="10" />
      <line x1="9" y1="4" x2="9" y2="20" />
      <line x1="15" y1="4" x2="15" y2="20" />
    </svg>
    <span class="text-xs">InPost</span>
  </div>

  <!-- 14 dni zwrotu -->
  <div class="flex items-center gap-1.5 text-gray-500">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="1 4 1 10 7 10" />
      <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10" />
    </svg>
    <span class="text-xs">14 dni zwrotu</span>
  </div>

  <!-- Bezpieczna platnosc -->
  <div class="flex items-center gap-1.5 text-gray-500">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
    </svg>
    <span class="text-xs">Bezpieczna platnosc</span>
  </div>
</div>
