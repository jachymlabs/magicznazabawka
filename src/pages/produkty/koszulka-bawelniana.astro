---
/**
 * Override strona dla "Koszulka bawełniana"
 *
 * WZORCOWA strona konwersyjna DTC — PL market optimized.
 * Scroll map z playbooka: Hero → Authority → Stats → Problem → Solution →
 * Benefits → Comparison → Testimonial → Reviews → Guarantee → FAQ → Final CTA
 *
 * GÓRA: Stała karta produktu (ProductDetail) — dane z Vendure
 * DÓŁ: Custom sekcje landing page — unikalne per produkt
 */
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProductDetail from '@/components/ProductDetail.astro';
import { shopApi, shopApiRaw, redirectWithToken } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { ADD_TO_CART } from '@/lib/mutations';
import { buildAssetUrl } from '@/lib/utils';
import type { VendureVariant } from '@/types/vendure';

// Section components
import FeaturesGrid from '@/components/sections/FeaturesGrid.astro';
import TestimonialQuote from '@/components/sections/TestimonialQuote.astro';
import StatsBar from '@/components/sections/StatsBar.astro';
import ComparisonTable from '@/components/sections/ComparisonTable.astro';
import ReviewsCarousel from '@/components/sections/ReviewsCarousel.astro';
import StickyATCBar from '@/components/StickyATCBar';

// New components
import FAQAccordion from '@/components/FAQAccordion';
import FinalCTA from '@/components/FinalCTA.astro';
import ReviewsSlot from '@/components/ReviewsSlot.astro';

const SLUG = 'koszulka-bawelniana';

// POST handler kept as no-JS fallback
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const variantId = formData.get('variantId') as string;
    const rawQty = parseInt(formData.get('quantity') as string || '1', 10);
    const quantity = Math.max(1, Math.min(99, isNaN(rawQty) ? 1 : rawQty));
    if (variantId) {
      const result = await shopApiRaw<any>(ADD_TO_CART, { variantId, quantity }, Astro.request);
      return redirectWithToken('/koszyk', result.authToken);
    }
  } catch {
    // Fall through
  }
}

// Fetch product from Vendure
const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug: SLUG }, Astro.request);
const product = data.product;
if (!product) return Astro.redirect('/');

const lowestPrice = product.variants?.length
  ? Math.min(...product.variants.map((v: VendureVariant) => v.priceWithTax))
  : 0;

// SEO
const ogImageUrl = product?.featuredAsset?.preview
  ? buildAssetUrl(product.featuredAsset.preview, 'large')
  : undefined;

const metaDescription = 'Koszulka z certyfikowanej bawelny organicznej GOTS. Wzmocnione szwy, oddychajacy material, hipoalergiczna. Szyta w Polsce. Wysylka InPost 24h. 30 dni na zwrot.';

// JSON-LD Product structured data
const allOutOfStock = product?.variants?.length > 0
  && product.variants.every((v: VendureVariant) => v.stockLevel === 'OUT_OF_STOCK');

const availability = allOutOfStock
  ? 'https://schema.org/OutOfStock'
  : 'https://schema.org/InStock';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: metaDescription,
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  brand: {
    '@type': 'Brand',
    name: 'Premium Organic',
  },
  // TODO: aggregateRating should come from a reviews system.
  // Hardcoded values may be flagged as spam by Google.
  // aggregateRating: { '@type': 'AggregateRating', ratingValue: '4.9', reviewCount: '1248' },
  offers: {
    '@type': 'Offer',
    price: (lowestPrice / 100).toFixed(2),
    priceCurrency: 'PLN',
    availability,
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        businessDays: {
          '@type': 'QuantitativeValue',
          minValue: 1,
          maxValue: 2,
        },
      },
    },
  },
};

// FAQ structured data for Google
const faqItems = [
  { question: 'Jaki jest czas dostawy?', answer: 'Zamowienia zlozone do 14:00 wysylamy tego samego dnia. Ponad 95% przesylek InPost dociera do Paczkomatow w ciagu 24 godzin.' },
  { question: 'Jak moge zwrocic produkt?', answer: 'Masz 30 dni na zwrot bez podawania przyczyny. Nadajesz paczke w dowolnym Paczkomacie InPost — calodobowo, bez kolejek. Pelny zwrot pieniedzy w 3 dni robocze.' },
  { question: 'Jakie rozmiary sa dostepne?', answer: 'Koszulka dostepna w rozmiarach S, M, L i XL. Tabela rozmiarow znajduje sie na stronie — jesli wahasz sie miedzy dwoma rozmiarami, wybierz wiekszy.' },
  { question: 'Czy moge placic BLIK-iem?', answer: 'Tak! Obslugujemy BLIK, szybkie przelewy (PayU), karty platnicze oraz PayPo (zaplac pozniej w ciagu 30 dni).' },
  { question: 'Jak prac koszulke?', answer: 'W pralce w 30°C. Nie uzywaj wybielacza. Koszulka nie kurczy sie, nie mechaci i nie farbuje — przetestowane na 100+ cyklach prania.' },
  { question: 'Skad pochodzi koszulka?', answer: 'Szyta w Polsce z certyfikowanej bawelny organicznej GOTS. Bez posrednikow — od producenta prosto do Ciebie.' },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout
  title={`${product.name} — Sklep`}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogType="product"
>

  {/* JSON-LD Structured Data */}
  <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} slot="head" />

  {/* ═══════════════════════════════════════════════════
      1. HERO — Stała karta produktu (dane z Vendure)
      ═══════════════════════════════════════════════════ */}
  <ProductDetail product={product} />

  {/* Sticky ATC bar — appears when scrolling past primary button */}
  {product.variants[0] && (
    <StickyATCBar
      client:idle
      productName={product.name}
      price={lowestPrice}
      variantId={product.variants[0].id}
    />
  )}

  {/* ═══════════════════════════════════════════════════
      2. AUTHORITY / PRESS LOGOS
      ═══════════════════════════════════════════════════ */}
  <section class="py-6 sm:py-8 border-b border-gray-100">
    <div class="mx-auto max-w-5xl px-4">
      <p class="text-center text-xs text-gray-400 uppercase tracking-wider mb-4">Wyroznieni przez</p>
      <div class="flex flex-wrap items-center justify-center gap-6 sm:gap-10">
        <div class="h-6 w-24 rounded bg-gray-200 flex items-center justify-center">
          <span class="text-[10px] text-gray-400 font-medium">Media 1</span>
        </div>
        <div class="h-6 w-20 rounded bg-gray-200 flex items-center justify-center">
          <span class="text-[10px] text-gray-400 font-medium">Media 2</span>
        </div>
        <div class="h-6 w-28 rounded bg-gray-200 flex items-center justify-center">
          <span class="text-[10px] text-gray-400 font-medium">Media 3</span>
        </div>
        <div class="h-6 w-22 rounded bg-gray-200 flex items-center justify-center">
          <span class="text-[10px] text-gray-400 font-medium">Media 4</span>
        </div>
        <div class="h-6 w-24 rounded bg-gray-200 flex items-center justify-center">
          <span class="text-[10px] text-gray-400 font-medium">Media 5</span>
        </div>
      </div>
      <p class="text-center text-xs text-gray-500 mt-4">Dolacz do ponad 2,400 zadowolonych klientow</p>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      3. STATS BAR
      ═══════════════════════════════════════════════════ */}
  <StatsBar
    theme="dark"
    stats={[
      { value: '2,400+', label: 'Sprzedanych sztuk' },
      { value: '100%', label: 'Bawelna organiczna GOTS' },
      { value: '4.9/5', label: 'Srednia ocena (1,248 opinii)' },
      { value: '24h', label: 'Wysylka InPost' },
    ]}
  />

  {/* ═══════════════════════════════════════════════════
      4. PROBLEM AGITATION
      ═══════════════════════════════════════════════════ */}
  <section class="py-12 sm:py-16 bg-gray-50">
    <div class="mx-auto max-w-4xl px-4">
      <h2 class="text-2xl font-bold text-gray-900 text-center sm:text-3xl mb-8">
        Znasz to uczucie?
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {/* Pain point 1 */}
        <div class="flex items-start gap-3">
          <div class="shrink-0 mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-red-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
          <div>
            <p class="font-medium text-gray-900">Koszulka traci ksztalt po 3 praniach</p>
            <p class="text-sm text-gray-500 mt-0.5">Rozciagniety kark, wygiete rekawy — klasyka</p>
          </div>
        </div>

        {/* Pain point 2 */}
        <div class="flex items-start gap-3">
          <div class="shrink-0 mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-red-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
          <div>
            <p class="font-medium text-gray-900">Sztuczne materialy podrazniaja skore</p>
            <p class="text-sm text-gray-500 mt-0.5">Swedzenie, zaczerwienienia, dyskomfort</p>
          </div>
        </div>

        {/* Pain point 3 */}
        <div class="flex items-start gap-3">
          <div class="shrink-0 mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-red-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
          <div>
            <p class="font-medium text-gray-900">Farbuje i mechaci sie po tygodniu</p>
            <p class="text-sm text-gray-500 mt-0.5">Nowa koszulka wyglada na znoszona po kilku praniach</p>
          </div>
        </div>

        {/* Pain point 4 */}
        <div class="flex items-start gap-3">
          <div class="shrink-0 mt-0.5 flex h-8 w-8 items-center justify-center rounded-full bg-red-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </div>
          <div>
            <p class="font-medium text-gray-900">Kupujesz 5 koszulek rocznie zamiast jednej dobrej</p>
            <p class="text-sm text-gray-500 mt-0.5">Fast fashion kosztuje wiecej niz myslisz</p>
          </div>
        </div>
      </div>

      <p class="text-center text-gray-600 mt-10 text-lg">
        A gdyby istniala koszulka, ktora wytrzyma <strong>100+ pran</strong> bez utraty formy?
      </p>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      5. SOLUTION / HOW IT WORKS — 3 kroki
      ═══════════════════════════════════════════════════ */}
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-4">
      <h2 class="text-2xl font-bold text-gray-900 text-center sm:text-3xl mb-10">
        Jak to dziala
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        {/* Krok 1 */}
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-green-100 mb-4">
            <span class="text-sm font-bold text-green-700">01</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Certyfikowana bawelna GOTS</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            Uprawiana bez pestycydow i sztucznych nawozow. Bezpieczna dla skory, przyjazna planecie.
          </p>
        </div>

        {/* Krok 2 */}
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-green-100 mb-4">
            <span class="text-sm font-bold text-green-700">02</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Podwojne wzmocnione szwy</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            Kark, rekawy, dol — wszedzie podwojna nic. Zachowuje ksztalt nawet po setnym praniu.
          </p>
        </div>

        {/* Krok 3 */}
        <div class="text-center">
          <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-green-100 mb-4">
            <span class="text-sm font-bold text-green-700">03</span>
          </div>
          <h3 class="font-semibold text-gray-900 mb-2">Oddychajacy splot</h3>
          <p class="text-sm text-gray-600 leading-relaxed">
            Naturalna wentylacja reguluje temperature. Nie przegrzewa latem, chroni zima.
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      6. BENEFITS BREAKDOWN (FeaturesGrid)
      ═══════════════════════════════════════════════════ */}
  <FeaturesGrid
    theme="accent"
    headline="Dlaczego ponad 2,400 osob wybralo te koszulke?"
    columns={3}
    features={[
      { icon: 'leaf', title: 'Bawelna organiczna GOTS', description: 'Bez chemii na Twojej skorze. Budzisz sie bez podraznien.' },
      { icon: 'shield-check', title: 'Wzmocnione szwy', description: 'Nie traci ksztaltu. Wyglada jak nowa po 100 praniach.' },
      { icon: 'wind', title: 'Oddychajacy material', description: 'Naturalna regulacja temperatury. Komfort przez caly dzien.' },
      { icon: 'heart', title: 'Hipoalergiczna', description: 'Bezpieczna dla wrazliwej skory. Idealna dla alergikow i dzieci.' },
      { icon: 'refresh-cw', title: 'Latwa pielegnacja', description: 'Pralka 30°C, gotowe. Zero dodatkowego zachodu.' },
      { icon: 'truck', title: 'Wysylka InPost 24h', description: 'Zamow do 14:00. Jutro masz w Paczkomacie.' },
    ]}
  />

  {/* ═══════════════════════════════════════════════════
      7. COMPARISON TABLE
      ═══════════════════════════════════════════════════ */}
  <ComparisonTable
    headline="Nasza koszulka vs zwykla z sieciowki"
    ourBrand="Premium Organic"
    competitor="Sieciowkowa koszulka"
    rows={[
      { feature: 'Bawelna organiczna GOTS', us: true, them: false },
      { feature: 'Bez pestycydow i chemii', us: true, them: false },
      { feature: 'Wzmocnione szwy', us: true, them: false },
      { feature: 'Nie kurczy sie po praniu', us: true, them: false },
      { feature: 'Hipoalergiczna', us: true, them: false },
      { feature: 'Oddychajacy material', us: true, them: true },
      { feature: 'Gwarancja 30 dni satysfakcji', us: true, them: false },
      { feature: 'Szyta w Polsce', us: true, them: false },
    ]}
  />

  {/* ═══════════════════════════════════════════════════
      8. TESTIMONIAL
      ═══════════════════════════════════════════════════ */}
  <TestimonialQuote
    theme="accent"
    quote="Kupilam te koszulke 8 miesiecy temu i piore ja co tydzien. Material jest dokladnie tak samo miekki jak na poczatku. Moj maz zamowil sobie 3 sztuki po tym jak zobaczyl moja — nie chce nosic niczego innego."
    authorName="Marta z Krakowa"
    authorTitle="Weryfikowany zakup, 8 miesiecy uzytkowania"
    rating={5}
  />

  {/* ═══════════════════════════════════════════════════
      9. REVIEWS CAROUSEL
      ═══════════════════════════════════════════════════ */}
  <ReviewsCarousel
    headline="Opinie klientow"
    reviews={[
      { body: 'Po 6 miesiacach noszenia wyglada identycznie. Zero mechacenia, zero kurczenia. Nareszcie koszulka na lata, nie na miesiace.', author: 'Tomek z Warszawy', rating: 5 },
      { body: 'Mam wrazliwa skore i wiekszosc koszulek powoduje swedzenie. Ta jest idealna — zero reakcji, sama miekkosc.', author: 'Anna z Gdanska', rating: 5 },
      { body: 'Zamowilam 2, dokupilam 3. Najlepsza inwestycja w szafe — przy takiej jakosci cena jest smiesznie niska.', author: 'Kasia z Wroclawia', rating: 5 },
      { body: 'Na poczatku myslalem ze to przesada, ale material naprawde jest inny. Oddychajacy, lekki, nie klei sie w upal.', author: 'Michal z Poznania', rating: 4 },
      { body: 'Kupilam mezowi na urodziny. Teraz kradne mu ja co drugi dzien. Musze zamowic swoja.', author: 'Ewa z Lodzi', rating: 5 },
    ]}
  />

  {/* ═══════════════════════════════════════════════════
      10. GUARANTEE SECTION
      ═══════════════════════════════════════════════════ */}
  <section class="py-12 sm:py-16 bg-gray-50">
    <div class="mx-auto max-w-2xl px-4">
      <div class="rounded-2xl border border-green-200 bg-green-50 p-6 sm:p-8 text-center">
        {/* Shield icon */}
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-green-100 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>

        <h2 class="text-xl font-bold text-gray-900 sm:text-2xl mb-3">
          Gwarancja satysfakcji — 30 dni na zwrot
        </h2>
        <p class="text-gray-600 leading-relaxed">
          Jesli koszulka Ci nie odpowiada, zwroc ja w ciagu 30 dni bez podawania przyczyny.
          Zwrot przez InPost — nadaj paczke calodobowo w najblizszym Paczkomacie.
          Pelny zwrot pieniedzy w 3 dni robocze.
        </p>
      </div>
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      11. FAQ ACCORDION (React island)
      ═══════════════════════════════════════════════════ */}
  <section class="py-12 sm:py-16 bg-white">
    <div class="mx-auto max-w-3xl px-4">
      <FAQAccordion
        client:visible
        title="Czesto zadawane pytania"
        items={faqItems}
      />
    </div>
  </section>

  {/* ═══════════════════════════════════════════════════
      12. FINAL CTA
      ═══════════════════════════════════════════════════ */}
  <FinalCTA
    productName={product.name}
    price={lowestPrice}
    variantId={product.variants[0]?.id}
    image={product.featuredAsset?.preview}
    urgencyText="Zamow do 14:00 — wysylka dzis!"
  />

  {/* ═══════════════════════════════════════════════════
      13. REVIEWS SLOT (zewnetrzne opinie)
      ═══════════════════════════════════════════════════ */}
  <ReviewsSlot title="Zewnetrzne opinie" />

  {/* Intercept ATC form — use async cart API + open drawer instead of redirect */}
  <script>
    function initAddToCartForm() {
      const form = document.querySelector('form[method="POST"]') as HTMLFormElement | null;
      if (!form) return;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (!btn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const variantId = formData.get('variantId') as string;
        const quantity = parseInt(formData.get('quantity') as string || '1', 10);

        if (!variantId) return;

        btn.disabled = true;
        const originalText = btn.textContent;
        btn.textContent = 'Dodawanie...';

        try {
          const res = await fetch('/api/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ variantId, quantity }),
          });

          if (res.ok) {
            const data = await res.json();
            window.dispatchEvent(new CustomEvent('cart-updated', { detail: data.order }));
          } else {
            form.submit();
            return;
          }
        } catch {
          form.submit();
          return;
        }

        btn.disabled = false;
        btn.textContent = originalText;
      });
    }
    initAddToCartForm();
  </script>
</BaseLayout>
