---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import Price from '@/components/Price.astro';
import Button from '@/components/Button.astro';
import TrustBadges from '@/components/TrustBadges.astro';
import StickyATCBar from '@/components/StickyATCBar';
import { shopApi, shopApiRaw, redirectWithToken } from '@/lib/vendure';
import { GET_PRODUCT_DETAIL } from '@/lib/queries';
import { ADD_TO_CART } from '@/lib/mutations';
import { sanitizeHtml } from '@/lib/sanitize';
import { buildAssetUrl } from '@/lib/utils';
import type { VendureProduct, VendureVariant, VendureAsset, VendureCollection } from '@/types/vendure';
import { sendCAPIEvent, buildUserData, generateEventId } from '@/lib/meta-capi';
import { getStoreConfig } from '@/lib/store-config';

const storeConfig = await getStoreConfig(Astro.request);
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

// Handle POST — add to cart
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const variantId = formData.get('variantId') as string;
    const rawQty = parseInt(formData.get('quantity') as string || '1', 10);
    const quantity = Math.max(1, Math.min(99, isNaN(rawQty) ? 1 : rawQty));

    if (variantId) {
      const result = await shopApiRaw<any>(ADD_TO_CART, { variantId, quantity }, Astro.request);

      // CAPI: AddToCart event — only send if user consented to tracking (RODO)
      const cookies = Astro.request.headers.get('cookie') || '';
      const hasConsent = cookies.includes('cookie_consent=accepted');
      if (hasConsent) {
        const userData = await buildUserData(Astro.request);
        sendCAPIEvent({
          event_name: 'AddToCart',
          event_time: Math.floor(Date.now() / 1000),
          event_id: generateEventId(),
          event_source_url: Astro.url.href,
          action_source: 'website',
          user_data: userData,
          custom_data: {
            content_ids: [variantId],
            content_type: 'product',
            currency: 'PLN',
          },
        }, storeConfig.metaDatasetId);
      }

      return redirectWithToken('/koszyk', result.authToken);
    }
    return Astro.redirect('/koszyk');
  } catch {
    // Fall through to render page with error state if needed
  }
}

let product: VendureProduct | null = null;
let error: string | null = null;

try {
  const data = await shopApi<any>(GET_PRODUCT_DETAIL, { slug }, Astro.request);
  product = data.product;
} catch (e: any) {
  error = 'Nie udalo sie zaladowac produktu. Sprobuj ponownie.';
}

if (!product && !error) {
  return Astro.rewrite('/404');
}

// CAPI: ViewContent (server-side) — consent-gated
// viewContentEventId is shared with browser pixel for deduplication (defined below, used in both)
const viewContentEventId = generateEventId();
if (product) {
  const vcCookies = Astro.request.headers.get('cookie') || '';
  const vcHasConsent = vcCookies.includes('cookie_consent=accepted');
  if (vcHasConsent) {
    const vcUserData = await buildUserData(Astro.request);
    const vcFirstVariant = product.variants?.[0];
    sendCAPIEvent({
      event_name: 'ViewContent',
      event_time: Math.floor(Date.now() / 1000),
      event_id: viewContentEventId,
      event_source_url: Astro.url.href,
      action_source: 'website',
      user_data: vcUserData,
      custom_data: {
        content_ids: [vcFirstVariant?.sku || product.id],
        content_name: product.name,
        content_type: 'product',
        value: vcFirstVariant ? vcFirstVariant.priceWithTax / 100 : 0,
        currency: 'PLN',
      },
    }, storeConfig.metaDatasetId);
  }
}

// Find parent collection for breadcrumbs
const parentCollection = product?.collections?.find((c: VendureCollection) => c.parent?.id === '1');

// Main image — featuredAsset or first asset
const mainImage = product?.featuredAsset || product?.assets?.[0];

// SEO: Strip HTML tags from description, max 160 chars
function stripHtml(html: string): string {
  return html.replace(/<[^>]*>/g, '').replace(/\s+/g, ' ').trim();
}

const rawDescription = product?.customFields?.shortDescription || product?.description || '';
const metaDescription = stripHtml(rawDescription).slice(0, 160);
const ogImageUrl = mainImage?.preview ? buildAssetUrl(mainImage.preview, 'large') : undefined;

// Stock status
const allOutOfStock = (product?.variants?.length ?? 0) > 0
  && product!.variants.every((v: VendureVariant) => v.stockLevel === 'OUT_OF_STOCK');

// JSON-LD: Product structured data
const lowestPrice = product?.variants?.length
  ? Math.min(...product.variants.map((v: VendureVariant) => v.priceWithTax))
  : 0;

const availability = allOutOfStock
  ? 'https://schema.org/OutOfStock'
  : 'https://schema.org/InStock';

const jsonLd = product ? {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: metaDescription,
  ...(ogImageUrl ? { image: ogImageUrl } : {}),
  sku: product.variants?.[0]?.sku || undefined,
  offers: {
    '@type': 'Offer',
    price: (lowestPrice / 100).toFixed(2),
    // TODO: Use product.variants[0].currencyCode when added to GET_PRODUCT_DETAIL query
    priceCurrency: 'PLN',
    availability,
    url: Astro.url.href,
  },
} : null;

// Stock count logic
const firstVariantStock = product?.variants?.[0]?.stockLevel;
const stockNum = parseInt(firstVariantStock, 10);
const showStockCritical = !isNaN(stockNum) && stockNum <= 2;
const showStockLow = !isNaN(stockNum) && stockNum > 2 && stockNum <= 5;

// Omnibus: najnizsza cena z 30 dni
const lowestPrice30d = product?.variants?.[0]?.customFields?.lowestPrice30d;
const firstVariantPrice = product?.variants?.[0]?.priceWithTax;
const showOmnibus = lowestPrice30d && lowestPrice30d > 0 && firstVariantPrice < lowestPrice30d;
const omnibusFormatted = showOmnibus
  ? new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(lowestPrice30d / 100)
  : '';

// ViewContent event data for browser pixel (viewContentEventId generated above for dedup)
const firstVariant = product?.variants?.[0];
---

<BaseLayout
  title={product?.name || 'Produkt'}
  description={metaDescription}
  ogImage={ogImageUrl}
  ogType="product"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
    {product ? (
      <>
        <Breadcrumbs items={[
          { label: 'Strona główna', href: '/' },
          ...(parentCollection ? [{ label: parentCollection.name, href: `/kolekcje/${parentCollection.slug}` }] : []),
          { label: product.name },
        ]} />

        <div class="mt-4 grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
          <!-- Image -->
          <div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
            {mainImage ? (
              <img
                src={buildAssetUrl(mainImage.preview, 'large')}
                alt={product.name}
                width="800"
                height="800"
                class="h-full w-full object-cover"
                fetchpriority="high"
                loading="eager"
              />
            ) : (
              <div class="flex h-full w-full items-center justify-center text-gray-400">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            )}
          </div>

          <!-- Product info + add to cart form -->
          <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{product.name}</h1>

            {allOutOfStock && (
              <span class="mt-2 inline-block rounded-full bg-red-100 px-3 py-1 text-xs font-semibold text-red-700">
                Niedostepny
              </span>
            )}

            {product.variants.length === 1 ? (
              <!-- Single variant — show price directly -->
              <Price price={product.variants[0].priceWithTax} class="mt-3 text-xl" />
            ) : (
              <!-- Multiple variants — show range -->
              <div class="mt-3">
                <Price
                  priceRange={{
                    __typename: 'PriceRange',
                    min: Math.min(...product.variants.map((v: VendureVariant) => v.priceWithTax)),
                    max: Math.max(...product.variants.map((v: VendureVariant) => v.priceWithTax)),
                  }}
                  class="text-xl"
                />
              </div>
            )}

            {/* Omnibus: najnizsza cena z 30 dni */}
            {showOmnibus && (
              <p class="mt-1 text-xs text-gray-500">
                Najnizsza cena z 30 dni: {omnibusFormatted}
              </p>
            )}

            {/* Stock count */}
            {showStockCritical && (
              <p class="mt-2 text-sm font-semibold text-red-600">
                Ostatnie {stockNum} {stockNum === 1 ? 'sztuka' : 'sztuki'}!
              </p>
            )}
            {showStockLow && (
              <p class="mt-2 text-sm font-medium text-amber-600">
                Zostalo {stockNum} sztuk
              </p>
            )}

            {/* Short description */}
            {/* TODO [H4]: set:html renders unescaped HTML from Vendure rich text custom field.
                Accepted risk for single-operator setup (admin-only input). If multi-tenant,
                add server-side HTML sanitization (e.g. sanitize-html). */}
            {product.customFields?.shortDescription && (
              <div
                class="mt-4 text-sm text-gray-600 leading-relaxed rich-text"
                set:html={sanitizeHtml(product.customFields.shortDescription)}
              />
            )}

            <form method="POST" class="mt-6 space-y-4">
              {/* Variant selector */}
              {product.variants.length > 1 ? (
                <div>
                  <label for="variantId" class="block text-sm font-medium text-gray-700 mb-1.5">
                    Wariant
                  </label>
                  <select
                    name="variantId"
                    id="variantId"
                    required
                    class="w-full rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm focus:border-gray-900 focus:ring-1 focus:ring-gray-900 focus:outline-none"
                  >
                    {product.variants.map((v: VendureVariant) => (
                      <option value={v.id} disabled={v.stockLevel === 'OUT_OF_STOCK'}>
                        {v.name} — {new Intl.NumberFormat('pl-PL', { style: 'currency', currency: 'PLN' }).format(v.priceWithTax / 100)}
                        {v.stockLevel === 'OUT_OF_STOCK' ? ' (brak)' : ''}
                      </option>
                    ))}
                  </select>
                </div>
              ) : (
                <input type="hidden" name="variantId" value={product.variants[0]?.id} />
              )}

              {/* Quantity */}
              <div>
                <label for="quantity" class="block text-sm font-medium text-gray-700 mb-1.5">
                  Ilosc
                </label>
                <input
                  type="number"
                  name="quantity"
                  id="quantity"
                  value="1"
                  min="1"
                  max="99"
                  required
                  class="w-20 rounded-lg border border-gray-300 px-3 py-2 text-sm text-center focus:border-gray-900 focus:ring-1 focus:ring-gray-900 focus:outline-none"
                />
              </div>

              {allOutOfStock ? (
                <button
                  type="button"
                  disabled
                  class="w-full sm:w-auto rounded-lg bg-gray-300 px-6 py-3 text-sm font-semibold text-gray-500 cursor-not-allowed"
                >
                  Niedostepny
                </button>
              ) : (
                <Button type="submit" variant="primary" size="lg" class="w-full sm:w-auto" id="primary-atc-btn">
                  Dodaj do koszyka
                </Button>
              )}

              {/* Shipping urgency */}
              <p id="shipping-urgency" class="text-sm text-green-700 font-medium mt-2"></p>
            </form>

            <TrustBadges />

            {/* Sticky Add to Cart bar — visible when primary ATC scrolls out of view */}
            {!allOutOfStock && product.variants[0] && (
              <StickyATCBar
                client:idle
                productName={product.name}
                price={lowestPrice}
                variantId={product.variants[0].id}
              />
            )}

            {/* Description */}
            {product.description && (
              <div class="mt-8 pt-8 border-t border-gray-200">
                <h2 class="text-lg font-semibold text-gray-900 mb-3">Opis</h2>
                <div class="prose prose-sm text-gray-600 max-w-none" set:html={sanitizeHtml(product.description)} />
              </div>
            )}
          </div>
        </div>

        {/* Additional images */}
        {(product.assets?.length ?? 0) > 1 && (
          <div class="mt-8">
            <h2 class="text-lg font-semibold text-gray-900 mb-3">Zdjecia</h2>

            {/* Mobile: horizontal scroll snap */}
            <div class="sm:hidden">
              <div class="gallery-scroll flex gap-2 overflow-x-auto snap-x snap-mandatory scroll-smooth pb-3 -mx-4 px-4">
                {product.assets.map((asset: VendureAsset) => (
                  <div class="snap-center shrink-0 w-[75vw] aspect-square overflow-hidden rounded-lg bg-gray-100">
                    <img
                      src={buildAssetUrl(asset.preview, 'medium')}
                      alt={product.name}
                      width="400"
                      height="400"
                      loading="lazy"
                      class="h-full w-full object-cover"
                    />
                  </div>
                ))}
              </div>
              {/* Pagination dots */}
              <div class="flex justify-center gap-1.5 mt-2">
                {product.assets.map((_: VendureAsset, i: number) => (
                  <span class="gallery-dot w-1.5 h-1.5 rounded-full bg-gray-300 transition-colors" data-index={i} />
                ))}
              </div>
            </div>

            {/* Desktop: 3-column grid */}
            <div class="hidden sm:grid sm:grid-cols-3 gap-2">
              {product.assets.map((asset: VendureAsset) => (
                <div class="aspect-square overflow-hidden rounded-lg bg-gray-100">
                  <img
                    src={buildAssetUrl(asset.preview, 'small')}
                    alt={product.name}
                    width="200"
                    height="200"
                    loading="lazy"
                    class="h-full w-full object-cover"
                  />
                </div>
              ))}
            </div>
          </div>
        )}
      </>
    ) : (
      <div class="py-12 text-center">
        <p class="text-gray-500">{error || 'Produkt nie zostal znaleziony.'}</p>
      </div>
    )}
  </div>

  {/* JSON-LD Structured Data */}
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  )}

  {/* ViewContent pixel event (browser-side, consent-gated via fbq check) */}
  {product && firstVariant && (
    <script
      is:inline
      define:vars={{
        vcEventId: viewContentEventId,
        vcContentName: product.name,
        vcContentIds: [firstVariant.sku || firstVariant.id],
        vcValue: lowestPrice / 100,
      }}
    >
      if (typeof fbq !== 'undefined') {
        fbq('track', 'ViewContent', {
          content_name: vcContentName,
          content_ids: vcContentIds,
          content_type: 'product',
          value: vcValue,
          currency: 'PLN',
        }, { eventID: vcEventId });
      }
    </script>
  )}

  {/* Intercept ATC form — use async cart API + open drawer instead of redirect */}
  <script>
    function initAddToCartForm() {
      const form = document.querySelector('form[method="POST"]') as HTMLFormElement | null;
      if (!form) return;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (!btn) return;

      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const variantId = formData.get('variantId') as string;
        const quantity = parseInt(formData.get('quantity') as string || '1', 10);

        if (!variantId) return;

        btn.disabled = true;
        const originalText = btn.textContent;
        btn.textContent = 'Dodawanie...';

        try {
          const res = await fetch('/api/cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ variantId, quantity }),
          });

          if (res.ok) {
            const data = await res.json();
            window.dispatchEvent(new CustomEvent('cart-updated', { detail: data.order }));
          } else {
            // Fallback: submit form normally
            form.submit();
            return;
          }
        } catch {
          // Fallback: submit form normally
          form.submit();
          return;
        }

        btn.disabled = false;
        btn.textContent = originalText;
      });
    }
    initAddToCartForm();
  </script>

  {/* Gallery scroll dots */}
  <script is:inline>
  (function() {
    var scroller = document.querySelector('.gallery-scroll');
    if (!scroller) return;
    var dots = document.querySelectorAll('.gallery-dot');
    if (!dots.length) return;
    dots[0].classList.remove('bg-gray-300');
    dots[0].classList.add('bg-gray-900');
    scroller.addEventListener('scroll', function() {
      var children = scroller.children;
      var scrollLeft = scroller.scrollLeft;
      var w = children[0].offsetWidth;
      var idx = Math.round(scrollLeft / (w + 8));
      dots.forEach(function(d, i) {
        d.classList.toggle('bg-gray-900', i === idx);
        d.classList.toggle('bg-gray-300', i !== idx);
      });
    });
  })();
  </script>

  {/* Shipping urgency countdown */}
  <script is:inline>
  (function() {
    var el = document.getElementById('shipping-urgency');
    if (!el) return;

    function update() {
      var now = new Date();
      var waw = new Date(now.toLocaleString('en-US', { timeZone: 'Europe/Warsaw' }));
      var day = waw.getDay();
      var hours = waw.getHours();
      var minutes = waw.getMinutes();

      if (day === 0 || day === 6) {
        el.textContent = 'Zamow teraz \u2014 wysylka w poniedzialek!';
        return;
      }

      var cutoff = 14;
      if (hours >= cutoff) {
        el.textContent = 'Zamow teraz \u2014 wysylka jutro!';
        return;
      }

      var remainH = cutoff - hours - 1;
      var remainM = 60 - minutes;
      if (remainM === 60) { remainM = 0; remainH++; }
      el.textContent = 'Zamow w ciagu ' + remainH + ' godz. ' + remainM + ' min \u2014 wysylka dzisiaj!';
    }

    update();
    const urgencyTimer = setInterval(update, 60000);
    document.addEventListener('astro:before-swap', () => clearInterval(urgencyTimer), { once: true });
  })();
  </script>
</BaseLayout>
