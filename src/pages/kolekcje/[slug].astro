---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import ProductCard from '@/components/ProductCard.astro';
import { shopApi } from '@/lib/vendure';
import { sanitizeHtml } from '@/lib/sanitize';
import { SEARCH_PRODUCTS, GET_COLLECTION } from '@/lib/queries';
import { buildAssetUrl } from '@/lib/utils';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const perPage = 24;
const pageParam = Astro.url.searchParams.get('page');
const page = Math.max(1, parseInt(pageParam || '1', 10) || 1);
const skip = (page - 1) * perPage;

let products: any[] = [];
let totalItems = 0;
let collection: any = null;
let error: string | null = null;

try {
  const [productsData, collectionData] = await Promise.all([
    shopApi<any>(SEARCH_PRODUCTS, {
      input: {
        collectionSlug: slug,
        groupByProduct: true,
        take: perPage,
        skip,
      },
    }, Astro.request),
    shopApi<any>(GET_COLLECTION, { slug }, Astro.request),
  ]);
  products = productsData.search?.items ?? [];
  totalItems = productsData.search?.totalItems ?? 0;
  collection = collectionData.collection;
} catch (e: any) {
  error = 'Nie udalo sie zaladowac produktow. Sprobuj ponownie.';
}

if (!collection && !error) {
  return Astro.rewrite('/404');
}

// Use collection name from API, fallback to slug-derived name
const collectionName = collection?.name || slug.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase());
const collectionDescription = collection?.description || null;
const collectionBanner = collection?.featuredAsset?.preview || null;

// Pagination
const totalPages = Math.ceil(totalItems / perPage);

function pageUrl(p: number): string {
  const url = new URL(Astro.url);
  if (p <= 1) {
    url.searchParams.delete('page');
  } else {
    url.searchParams.set('page', String(p));
  }
  return url.pathname + url.search;
}

// Generate page numbers to show (max 7 with ellipsis)
function getPageNumbers(current: number, total: number): (number | '...')[] {
  if (total <= 7) return Array.from({ length: total }, (_, i) => i + 1);
  const pages: (number | '...')[] = [];
  pages.push(1);
  if (current > 3) pages.push('...');
  for (let i = Math.max(2, current - 1); i <= Math.min(total - 1, current + 1); i++) {
    pages.push(i);
  }
  if (current < total - 2) pages.push('...');
  pages.push(total);
  return pages;
}

const pageNumbers = getPageNumbers(page, totalPages);
---

<BaseLayout title={collectionName} description={collectionDescription ? collectionDescription.replace(/<[^>]*>/g, '').slice(0, 160) : `Produkty z kolekcji ${collectionName}`}>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-6">
    <Breadcrumbs items={[
      { label: 'Strona glowna', href: '/' },
      { label: collectionName },
    ]} />

    {/* Collection banner */}
    {collectionBanner && (
      <div class="mt-4 aspect-[4/1] overflow-hidden rounded-lg bg-gray-100">
        <img
          src={buildAssetUrl(collectionBanner, 'large')}
          alt={collectionName}
          class="h-full w-full object-cover"
        />
      </div>
    )}

    <div class="flex items-baseline justify-between mt-4 mb-4">
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900">{collectionName}</h1>
      {totalItems > 0 && (
        <span class="text-sm text-gray-500">{totalItems} produktow</span>
      )}
    </div>

    {/* Collection description */}
    {collectionDescription && (
      <div class="mb-6 text-sm text-gray-600 leading-relaxed prose prose-sm max-w-none" set:html={sanitizeHtml(collectionDescription)} />
    )}

    {error && (
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
        <p class="text-sm text-red-700">{error}</p>
      </div>
    )}

    {products.length > 0 ? (
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
        {products.map((p: any) => (
          <ProductCard
            name={p.productName}
            slug={p.slug}
            imageUrl={p.productAsset?.preview}
            priceWithTax={p.priceWithTax}
            currencyCode={p.currencyCode}
          />
        ))}
      </div>
    ) : !error ? (
      <p class="text-gray-500 py-12 text-center">Brak produktow w tej kolekcji.</p>
    ) : null}

    {/* Pagination */}
    {totalPages > 1 && (
      <nav class="mt-10 flex items-center justify-center gap-1" aria-label="Paginacja">
        {/* Prev */}
        {page > 1 ? (
          <a
            href={pageUrl(page - 1)}
            class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
            aria-label="Poprzednia strona"
          >
            &larr;
          </a>
        ) : (
          <span class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm font-medium text-gray-300 cursor-not-allowed">
            &larr;
          </span>
        )}

        {/* Page numbers */}
        {pageNumbers.map((p) =>
          p === '...' ? (
            <span class="inline-flex items-center justify-center px-2 py-2 text-sm text-gray-400">...</span>
          ) : p === page ? (
            <span class="inline-flex items-center justify-center rounded-lg bg-gray-900 px-3 py-2 text-sm font-medium text-white min-w-[2.5rem]">
              {p}
            </span>
          ) : (
            <a
              href={pageUrl(p as number)}
              class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors min-w-[2.5rem]"
            >
              {p}
            </a>
          )
        )}

        {/* Next */}
        {page < totalPages ? (
          <a
            href={pageUrl(page + 1)}
            class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors"
            aria-label="Nastepna strona"
          >
            &rarr;
          </a>
        ) : (
          <span class="inline-flex items-center justify-center rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm font-medium text-gray-300 cursor-not-allowed">
            &rarr;
          </span>
        )}
      </nav>
    )}
  </div>

  {collection && (
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": collectionName,
      "description": collectionDescription || undefined,
      "url": Astro.url.href,
    })} slot="head" />
  )}
</BaseLayout>
